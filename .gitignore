# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Environment variables
.env

# Local-only planning artifacts (DB dumps, run logs, secret notes — never committed)
.planning/phases/**/*.sql
.planning/phases/**/*.log
.planning/phases/**/*.local.md

# Terraform (Phase 3 — bootstrap state must NEVER be committed; prod state lives in Azure Blob)
infra/bootstrap/.terraform/
infra/bootstrap/terraform.tfstate
infra/bootstrap/terraform.tfstate.backup
infra/bootstrap/.terraform.lock.hcl
infra/envs/*/.terraform/
infra/envs/*/.terraform.lock.hcl
*.tfplan
*.tfvars.local

