# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Environment variables
.env

# Local-only Docker Compose override (per-machine port mappings, etc.)
docker-compose.override.yml

# Local-only planning artifacts (DB dumps, run logs, secret notes — never committed)
.planning/phases/**/*.sql
.planning/phases/**/*.log
.planning/phases/**/*.local.md

# Terraform (Phase 3 — bootstrap state must NEVER be committed; prod state lives in Azure Blob)
infra/bootstrap/.terraform/
infra/bootstrap/terraform.tfstate
infra/bootstrap/terraform.tfstate.backup
infra/bootstrap/.terraform.lock.hcl
infra/envs/*/.terraform/
infra/envs/*/.terraform.lock.hcl
*.tfplan
*.tfvars.local

# Phase 4 D-02 — infra/external/ local-state-only (mirrors infra/bootstrap/)
infra/external/terraform.tfstate
infra/external/terraform.tfstate.backup
infra/external/.terraform/
infra/external/.terraform.lock.hcl
infra/external/*.tfvars.local
infra/external/*.tfplan

# Local-only TF runtime artifacts (crash dumps + apply logs)
infra/envs/*/errored.tfstate
infra/envs/*/*-apply.log


# macOS Finder metadata
.DS_Store
**/.DS_Store
