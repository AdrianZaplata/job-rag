DATABASE_URL=postgresql://postgres:postgres@localhost:5432/job_rag
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/job_rag
OPENAI_API_KEY=sk-your-key-here
POSTGRES_PASSWORD=change-me-to-a-strong-password
JOB_RAG_API_KEY=

# CORS allow-list for FastAPI app (D-26): comma-separated, NEVER '*'.
ALLOWED_ORIGINS=http://localhost:5173

# Per-request agent timeout in seconds (D-25). Must be >= 1 (Pydantic ge=1 guard).
AGENT_TIMEOUT_SECONDS=60

# SSE heartbeat cadence in seconds (D-15). Must be >= 1.
HEARTBEAT_INTERVAL_SECONDS=15

# SEEDED_USER_ID is NOT an env var - it is a Python constant in src/job_rag/config.py
# (T-01-02 / D-08). Do not attempt to override via environment.
