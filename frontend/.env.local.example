# Dev VITE_* values. Copy to .env.local (gitignored).
# All values are PUBLIC-BY-DESIGN (visible in JWT iss/aud claims).

# Entra External ID (CIAM) tenant — from infra/bootstrap/ outputs
VITE_TENANT_SUBDOMAIN=jobrag
VITE_TENANT_ID=00000000-0000-0000-0000-000000000000

# SPA + API app reg client IDs — from infra/external/ outputs
VITE_SPA_CLIENT_ID=00000000-0000-0000-0000-000000000000
VITE_API_AUDIENCE=api://00000000-0000-0000-0000-000000000000

# Local dev API base — proxied via vite.config.ts
VITE_API_BASE_URL=http://localhost:8000

# Set to true to enable /debug/agent-stream in this build.
VITE_DEBUG_PAGES=true
