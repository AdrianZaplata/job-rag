    "/dashboard/top-skills": {
      "get": {
        "tags": [
          "dashboard"
        ],
        "summary": "Dashboard Top Skills",
        "description": "Top-N skills with must-have / nice-to-have split (DASH-01).\n\nSoft skills hidden by default (D-13); pass ``?include_soft=true`` to include.\nReturns ``DashboardTopSkillsResponse`` with named OpenAPI schema (drives\nopenapi-typescript codegen).",
        "operationId": "dashboard_top_skills_dashboard_top_skills_get",
        "security": [
          {
            "HTTPBearer": []
          },
          {
            "AzureAD_PKCE_B2C_multi_tenant": []
          }
        ],
        "parameters": [
          {
            "name": "country",
            "in": "query",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/CountryFilter",
              "default": "WW"
            }
          },
          {
            "name": "seniority",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "$ref": "#/components/schemas/Seniority"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Seniority"
            }
          },
          {
            "name": "remote",
            "in": "query",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/RemoteFilter",
              "default": "any"
            }
          },
          {
            "name": "include_soft",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false,
              "title": "Include Soft"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 200,
              "minimum": 1,
              "default": 50,
              "title": "Limit"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DashboardTopSkillsResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/dashboard/salary-bands": {
      "get": {
        "tags": [
          "dashboard"
        ],
        "summary": "Dashboard Salary Bands",
        "description": "Salary percentiles p25/p50/p75 via PostgreSQL ``percentile_cont`` (DASH-02).\n\nReturns ``DashboardSalaryBandsResponse``; ``p25/p50/p75`` are ``int | None``\n(NULL when the filter matches zero salary-bearing postings - RESEARCH Pitfall 2).\nPer-period normalization: ``month`` -> x12; ``hour`` rows excluded (Pitfall 3).",
        "operationId": "dashboard_salary_bands_dashboard_salary_bands_get",
        "security": [
          {
            "HTTPBearer": []
          },
          {
            "AzureAD_PKCE_B2C_multi_tenant": []
          }
        ],
        "parameters": [
          {
            "name": "country",
            "in": "query",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/CountryFilter",
              "default": "WW"
            }
          },
          {
            "name": "seniority",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "$ref": "#/components/schemas/Seniority"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Seniority"
            }
          },
          {
            "name": "remote",
            "in": "query",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/RemoteFilter",
              "default": "any"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DashboardSalaryBandsResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/dashboard/cv-vs-market": {
      "get": {
        "tags": [
          "dashboard"
        ],
        "summary": "Dashboard Cv Vs Market",
        "description": "CV-vs-market aggregate match score (DASH-03).\n\nD-12 zero-postings contract: when the filter matches zero postings, returns\n``{mean_score: null, postings_compared: 0, top_missing_must_have: []}`` with\nHTTP 200 (NOT 404 like ``/gaps``).\n\nUses the existing ``match_posting()`` formula unchanged (D-10).",
        "operationId": "dashboard_cv_vs_market_dashboard_cv_vs_market_get",
        "security": [
          {
            "HTTPBearer": []
          },
          {
            "AzureAD_PKCE_B2C_multi_tenant": []
          }
        ],
        "parameters": [
          {
            "name": "country",
            "in": "query",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/CountryFilter",
              "default": "WW"
            }
          },
          {
            "name": "seniority",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "$ref": "#/components/schemas/Seniority"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Seniority"
            }
          },
          {
            "name": "remote",
            "in": "query",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/RemoteFilter",
              "default": "any"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DashboardCvMatchResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/agent": {
      "post": {
        "summary": "Agent Query",
        "description": "Run the LangGraph agent to completion on a single query.",
        "operationId": "agent_query_agent_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AgentQuery"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Agent Query Agent Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    },
    "/agent/stream": {
      "post": {
        "summary": "Agent Stream",
        "description": "Stream agent execution as SSE: typed events + heartbeat + 60s timeout + drain.\n\nThe handler wraps the Plan 04 ``stream_agent`` async iterator in\n``asyncio.timeout(settings.agent_timeout_seconds)`` (D-25) so a runaway\nLangGraph reasoning loop cannot block forever. Three exception branches\neach emit a typed ``ErrorEvent`` (D-19) before closing:\n\n- ``TimeoutError`` \u2192 ``reason=\"agent_timeout\"``\n- ``CancelledError`` \u2192 ``reason=\"shutdown\"`` (then re-raises so sse-starlette\n  can complete the cancellation handshake)\n- any other ``Exception`` \u2192 ``reason=\"internal\"`` with sanitized message\n\nThe current task is registered in ``app.state.active_streams`` on entry\nand discarded in ``finally`` \u2014 Plan 05's lifespan shutdown drains this set\nvia ``asyncio.gather(*active_streams)`` with a 30s grace period (D-17).\n\nsse-starlette's ``ping_message_factory`` is overridden so the keep-alive\nis a real ``event: heartbeat`` rather than a comment-only ``:ping`` (D-15).\nDefensive headers (``X-Accel-Buffering: no`` + ``Content-Encoding: identity``)\nprevent reverse-proxy/CDN buffering and accidental compression that would\nbreak EventSource parsing (D-18 / Pitfall 6).",
        "operationId": "agent_stream_agent_stream_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AgentQuery"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Stream of AgentEvent variants (token, tool_start, tool_end, heartbeat, error, final)",
            "content": {
              "application/json": {
                "schema": {}
              },
              "text/event-stream": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/TokenEvent"
                    },
                    {
                      "$ref": "#/components/schemas/ToolStartEvent"
                    },
                    {
                      "$ref": "#/components/schemas/ToolEndEvent"
                    },
                    {
                      "$ref": "#/components/schemas/HeartbeatEvent"
                    },
                    {
                      "$ref": "#/components/schemas/ErrorEvent"
                    },
                    {
                      "$ref": "#/components/schemas/FinalEvent"
                    }
                  ],
                  "discriminator": {
                    "propertyName": "type",
                    "mapping": {
                      "error": "#/components/schemas/ErrorEvent",
                      "final": "#/components/schemas/FinalEvent",
                      "heartbeat": "#/components/schemas/HeartbeatEvent",
                      "token": "#/components/schemas/TokenEvent",
                      "tool_end": "#/components/schemas/ToolEndEvent",
                      "tool_start": "#/components/schemas/ToolStartEvent"
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    },
    "/ingest": {
      "post": {
        "summary": "Ingest",
        "description": "Ingest a single job posting markdown file via the async pipeline.\n\nPre-Plan-06, this route called ``ingest_file(SessionLocal(), tmp_path)`` \u2014\nPlan 03's rewrap of ``ingest_file`` uses ``asyncio.run`` internally, which\nraises ``RuntimeError`` when called from an already-running event loop\n(i.e. inside any ``async def`` route). Plan 06 closes the latent crash by\ncalling the async ``ingest_from_source`` directly with the request's\nAsyncSession dependency (D-24).\n\nError strings in ``error_details`` are sanitized via ``_sanitize`` (T-06-06)\nso per-source extraction failures cannot leak stack traces to the API\nboundary \u2014 same helper used by the ``/agent/stream`` error event path.\n\nThe ``user_id`` dep is wired so future plans (Phase 7 PROF-01 onward) can\nscope ingestion writes to a user without a signature change. Today the\nvalue is the single seeded user; the dep itself is the multi-tenancy hook.",
        "operationId": "ingest_ingest_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_ingest_ingest_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Ingest Ingest Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          },
          {
            "AzureAD_PKCE_B2C_multi_tenant": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "AgentQuery": {
        "properties": {
          "query": {
            "type": "string",
            "title": "Query"
          }
        },
        "type": "object",
        "required": [
          "query"
        ],
        "title": "AgentQuery"
      },
      "Body_ingest_ingest_post": {
        "properties": {
          "file": {
            "type": "string",
            "contentMediaType": "application/octet-stream",
            "title": "File"
          }
        },
        "type": "object",
        "required": [
          "file"
        ],
        "title": "Body_ingest_ingest_post"
      },
      "CountryFilter": {
        "type": "string",
        "enum": [
          "PL",
          "DE",
          "EU",
          "WW"
        ],
        "title": "CountryFilter",
        "description": "Canonical 4-value country filter (D-07).\n\nPL/DE: exact ISO-3166 alpha-2 match.\nEU:    union of EU-27 ISO codes OR location_region == 'EU' (catches NULL-country\n       \"Remote (EU)\" postings per Phase 2 D-09).\nWW:    no filter (default; matches Worldwide)."
      },
      "DashboardCvMatchResponse": {
        "properties": {
          "mean_score": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Mean Score",
            "description": "Arithmetic mean of per-posting match_posting() scores; None when postings_compared == 0 (D-12)"
          },
          "postings_compared": {
            "type": "integer",
            "title": "Postings Compared",
            "description": "Number of filtered postings compared against the profile"
          },
          "top_missing_must_have": {
            "items": {
              "$ref": "#/components/schemas/MissingSkillItem"
            },
            "type": "array",
            "title": "Top Missing Must Have",
            "description": "Top 3 missing must-have skills ranked by frequency (Counter.most_common(3))"
          }
        },
        "type": "object",
        "required": [
          "mean_score",
          "postings_compared",
          "top_missing_must_have"
        ],
        "title": "DashboardCvMatchResponse",
        "description": "GET /dashboard/cv-vs-market response.\n\n`mean_score` is `float | None` because D-12 zero-postings case returns\n`{mean_score: None, postings_compared: 0, top_missing_must_have: []}` with\nHTTP 200 (NOT 404)."
      },
      "DashboardSalaryBandsResponse": {
        "properties": {
          "p25": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "P25",
            "description": "25th percentile annual salary in EUR"
          },
          "p50": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "P50",
            "description": "Median (50th percentile) annual salary in EUR"
          },
          "p75": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "P75",
            "description": "75th percentile annual salary in EUR"
          },
          "postings_with_salary": {
            "type": "integer",
            "title": "Postings With Salary",
            "description": "Number of filtered postings that had salary data (numerator of sample-size footnote)"
          },
          "total_postings": {
            "type": "integer",
            "title": "Total Postings",
            "description": "Total filtered postings (denominator of sample-size footnote)"
          },
          "currency": {
            "type": "string",
            "title": "Currency",
            "description": "ISO 4217 currency code; v1 hardcodes EUR",
            "default": "EUR"
          }
        },
        "type": "object",
        "required": [
          "p25",
          "p50",
          "p75",
          "postings_with_salary",
          "total_postings"
        ],
        "title": "DashboardSalaryBandsResponse",
        "description": "GET /dashboard/salary-bands response.\n\nPercentile fields are `int | None` because PostgreSQL `percentile_cont` returns\nNULL on empty result sets (RESEARCH Pitfall 2). The frontend reads `p50 is null`\nas the empty-state condition."
      },
      "DashboardTopSkillsResponse": {
        "properties": {
          "skills": {
            "items": {
              "$ref": "#/components/schemas/TopSkillItem"
            },
            "type": "array",
            "title": "Skills",
            "description": "Top-N skills (capped at the `limit` query param) ordered by total DESC"
          },
          "total_postings": {
            "type": "integer",
            "title": "Total Postings",
            "description": "Total postings matching the filter (footnote denominator)"
          },
          "unique_skills": {
            "type": "integer",
            "title": "Unique Skills",
            "description": "Distinct skill count (after soft-skill filter, if applied)"
          }
        },
        "type": "object",
        "required": [
          "skills",
          "total_postings",
          "unique_skills"
        ],
        "title": "DashboardTopSkillsResponse",
        "description": "GET /dashboard/top-skills response."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "MissingSkillItem": {
        "properties": {
          "skill": {
            "type": "string",
            "title": "Skill",
            "description": "Missing must-have skill identifier"
          },
          "count": {
            "type": "integer",
            "title": "Count",
            "description": "Number of filtered postings missing this must-have"
          },
          "percentage": {
            "type": "number",
            "title": "Percentage",
            "description": "count / total_postings * 100, rounded to 1 decimal"
          }
        },
        "type": "object",
        "required": [
          "skill",
          "count",
          "percentage"
        ],
        "title": "MissingSkillItem",
        "description": "One row in the cv-vs-market top-3 missing must-have list."
      },
      "RemoteFilter": {
        "type": "string",
        "enum": [
          "any",
          "remote",
          "non_remote"
        ],
        "title": "RemoteFilter",
